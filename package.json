{
  "name": "openclaw-electron",
  "version": "1.0.0",
  "description": "OpenClaw Electron Desktop Client",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npm run build:css",
    "build:css": "npx @tailwindcss/cli -i renderer/styles.css -o renderer/styles-compiled.css",
    "dev": "npm run build:css && tsc && electron .",
    "start": "electron .",
    "watch": "tsc --watch"
  },
  "keywords": [
    "openclaw",
    "electron",
    "desktop"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^34.0.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.2"
  }
}
